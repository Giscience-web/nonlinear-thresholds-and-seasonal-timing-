# ============================================================
# 2. Compute marginal cooling capacity
# ============================================================

def compute_marginal_capacity(df, feature=FEATURE, smooth_win=3):
    """
    For each group_type/group curve:
        x = EVI bin mean
        y = matched cooling benefit
        marginal capacity = dy / dx
    """
    rows = []

    for (gtype, group), sub in df.groupby(["group_type", "group"]):
        sub = sub.sort_values("x_target_mean").reset_index(drop=True).copy()

        if len(sub) < 3:
            continue

        x = sub["x_target_mean"].values.astype(float)
        y = sub["mean_cooling_benefit"].values.astype(float)

        dx = np.diff(x)
        dy = np.diff(y)

        mcc = np.full_like(dy, np.nan, dtype=float)
        valid = np.isfinite(dx) & np.isfinite(dy) & (dx != 0)
        mcc[valid] = dy[valid] / dx[valid]

        # assign marginal value to segment midpoint
        x_mid = (x[:-1] + x[1:]) / 2.0
        cb_left = y[:-1]
        cb_right = y[1:]

        # smooth for interpretation only
        mcc_smooth = (
            pd.Series(mcc)
            .rolling(smooth_win, center=True, min_periods=1)
            .mean()
            .values
        )

        for i in range(len(mcc)):
            rows.append({
                "feature": feature,
                "group_type": gtype,
                "group": group,
                "segment_id": i,
                "x_left": float(x[i]),
                "x_right": float(x[i + 1]),
                "x_mid": float(x_mid[i]),
                "cooling_benefit_left": float(cb_left[i]),
                "cooling_benefit_right": float(cb_right[i]),
                "delta_cooling_benefit": float(dy[i]),
                "delta_EVI": float(dx[i]),
                "marginal_cooling_capacity": float(mcc[i]),
                "marginal_cooling_capacity_smooth": float(mcc_smooth[i]),
            })

    return pd.DataFrame(rows)


