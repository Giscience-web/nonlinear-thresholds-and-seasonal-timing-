def find_col_by_patterns(columns, patterns):
    for pat in patterns:
        for c in columns:
            if pat.lower() in str(c).lower():
                return c
    return None

def get_colmap(df_in):
    return {k: find_col_by_patterns(df_in.columns, v) for k, v in CONTROL_PATTERNS.items()}

def interpolate_rows(mat):
    tmp = pd.DataFrame(mat).interpolate(axis=1, limit_direction="both").values.astype(float)
    row_mean = np.nanmean(tmp, axis=1)
    bad = ~np.isfinite(tmp)
    if bad.any():
        inds = np.where(bad)
        tmp[inds] = np.take(row_mean, inds[0])
    return tmp

def rowwise_onset(evi_wide):
    mat0 = evi_wide.values.astype(float)
    valid_count = np.isfinite(mat0).sum(axis=1)

    mat = interpolate_rows(mat0)

    left = np.concatenate([mat[:, [0]], mat[:, :-1]], axis=1)
    right = np.concatenate([mat[:, 1:], mat[:, [-1]]], axis=1)
    sm = (left + mat + right) / 3.0

    diff = np.diff(sm, axis=1)
    maxdiff = np.nanmax(diff, axis=1)
    idx = np.nanargmax(diff, axis=1)

    onset = idx + 2
    onset = onset.astype(float)
    onset[(valid_count < 6) | (maxdiff <= 0)] = np.nan

    return onset

def shift_late_curve_earlier(late_curve, onset_gap):
    """
    Shift late EVI curve earlier by onset_gap months.
    """
    d = int(round(onset_gap))
    shifted = np.full_like(late_curve, np.nan, dtype=float)

    if d <= 0:
        return late_curve.copy()

    if d >= len(late_curve):
        return shifted

    shifted[:-d] = late_curve[d:]
    return shifted

def evi_shape_rmse_after_shift(early_curve, late_curve, onset_gap):
    shifted = shift_late_curve_earlier(late_curve, onset_gap)
    ok = np.isfinite(early_curve) & np.isfinite(shifted)

    if ok.sum() < MIN_SHAPE_OVERLAP:
        return np.nan

    return float(np.sqrt(np.mean((early_curve[ok] - shifted[ok]) ** 2)))

def robust_peak_time_month(values, months):
    """
    Robust peak time as mean month of top-2 LST anomaly values.
    """
    values = np.asarray(values, dtype=float)
    months = np.asarray(months, dtype=float)

    ok = np.isfinite(values)
    values = values[ok]
    months = months[ok]

    if len(values) == 0:
        return np.nan

    k = min(2, len(values))
    idx = np.argsort(values)[-k:]
    peak_month = float(np.mean(months[idx]))
    return peak_month

def compute_observed_metrics(lst_month_values, warm_idx, all_months):
    """
    Compute metrics analogous to ML simulation, but on monthly observed LST anomaly.
    """
    x = np.asarray(lst_month_values, dtype=float)
    months = np.asarray(all_months, dtype=int)

    warm_x = x[warm_idx]

    warm_p95 = float(np.nanpercentile(warm_x, 95))

    # Heat load relative to 0 LST anomaly:
    # positive LST anomaly months contribute to heat load.
    heat_load = float(np.nansum(np.maximum(warm_x, 0)) * MONTH_DAYS)

    peak_month = robust_peak_time_month(x, months)
    peak_doy = float(MONTH_TO_DOY.get(int(round(peak_month)), np.nan)) if np.isfinite(peak_month) else np.nan

    return {
        "warm_p95": warm_p95,
        "heat_load": heat_load,
        "peak_month": peak_month,
        "peak_doy": peak_doy,
    }

def standardized_mean_difference(a, b):
    a = pd.to_numeric(pd.Series(a), errors="coerce").replace([np.inf, -np.inf], np.nan).dropna()
    b = pd.to_numeric(pd.Series(b), errors="coerce").replace([np.inf, -np.inf], np.nan).dropna()

    if len(a) < 2 or len(b) < 2:
        return np.nan

    sd = np.sqrt((np.var(a, ddof=1) + np.var(b, ddof=1)) / 2)
    if sd == 0 or not np.isfinite(sd):
        return np.nan

    return float((np.mean(a) - np.mean(b)) / sd)

