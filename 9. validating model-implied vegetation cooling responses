    py[f"spring_{c}"] = w[PRE_MONTHS].mean(axis=1).values
    py[f"warm_{c}"] = w[WARM_MONTHS].mean(axis=1).values
    py[f"traj_{c}_mean"] = w[TRAJ_MONTHS].mean(axis=1).values
    py[f"traj_{c}_amp"] = (w[TRAJ_MONTHS].max(axis=1) - w[TRAJ_MONTHS].min(axis=1)).values

# LAI optional amount metrics
if "LAI.LAI" in monthly.columns:
