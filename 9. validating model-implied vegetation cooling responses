# ============================================================
# 6. Match within one city-year
# ============================================================

evi_full_cols = [f"EVI_full_m{m:02d}" for m in range(1, 13)]
evi_traj_cols = [f"EVI_m{m:02d}" for m in TRAJ_MONTHS]
lst_traj_cols = [f"LST_m{m:02d}" for m in TRAJ_MONTHS]

warm_idx = np.array([TRAJ_MONTHS.index(m) for m in WARM_MONTHS], dtype=int)
months_arr = np.array(TRAJ_MONTHS, dtype=int)

def match_one_city_year(g):
    g = g.replace([np.inf, -np.inf], np.nan)
    g = g.dropna(subset=["t_EVI_onset_month"] + control_cols + lst_traj_cols + evi_traj_cols)

    if len(g) < MIN_PIXEL_YEARS_CITY_YEAR:
        return None, None

    q_early = g["t_EVI_onset_month"].quantile(EARLY_Q)
    q_late = g["t_EVI_onset_month"].quantile(LATE_Q)

    early = g[g["t_EVI_onset_month"] <= q_early].copy()
    late = g[g["t_EVI_onset_month"] >= q_late].copy()

    if len(early) < MIN_MATCHED_PAIRS or len(late) < MIN_MATCHED_PAIRS:
        return None, None

    if len(early) > MAX_EARLY_PER_CITY_YEAR:
        early = early.sample(n=MAX_EARLY_PER_CITY_YEAR, random_state=RANDOM_SEED)

    if len(late) > MAX_LATE_PER_CITY_YEAR:
        late = late.sample(n=MAX_LATE_PER_CITY_YEAR, random_state=RANDOM_SEED)

    scaler = StandardScaler()
    scaler.fit(pd.concat([early[control_cols], late[control_cols]], axis=0).astype(float).values)

    X_early = scaler.transform(early[control_cols].astype(float).values)
    X_late = scaler.transform(late[control_cols].astype(float).values)

    k = min(K_CANDIDATES, len(late))
    nn = NearestNeighbors(n_neighbors=k)
    nn.fit(X_late)

    dist, idx = nn.kneighbors(X_early)

    early_evi_full = early[evi_full_cols].values.astype(float)
    late_evi_full = late[evi_full_cols].values.astype(float)

    early_lst = early[lst_traj_cols].values.astype(float)
    late_lst = late[lst_traj_cols].values.astype(float)

    selected = []

    for i in range(len(early)):
        e_onset = early["t_EVI_onset_month"].iloc[i]
        best = None

        for kk in range(k):
            j = idx[i, kk]
            control_distance = dist[i, kk]

            if control_distance > MAX_CONTROL_DISTANCE:
                continue

            l_onset = late["t_EVI_onset_month"].iloc[j]
            onset_gap = l_onset - e_onset

            if onset_gap <= 0:
                continue

            if USE_SHAPE_FILTER:
                rmse = evi_shape_rmse_after_shift(
                    early_evi_full[i],
                    late_evi_full[j],
                    onset_gap
                )

                if (not np.isfinite(rmse)) or (rmse > MAX_EVI_SHAPE_RMSE):
                    continue
            else:
                rmse = np.nan

            score = control_distance + 8.0 * (rmse if np.isfinite(rmse) else 0) + 0.10 * abs(onset_gap)

            if best is None or score < best["score"]:
                best = {
                    "early_i": i,
                    "late_j": j,
                    "control_distance": control_distance,
                    "evi_shape_rmse": rmse,
                    "onset_gap": onset_gap,
                    "score": score
                }

        if best is not None:
            selected.append(best)

    if len(selected) < MIN_MATCHED_PAIRS:
        return None, None

    pair_rows = []

    for s in selected:
        i = s["early_i"]
        j = s["late_j"]

        e = early.iloc[i]
        l = late.iloc[j]

        e_lst = early_lst[i]
        l_lst = late_lst[j]

        e_met = compute_observed_metrics(e_lst, warm_idx, months_arr)
        l_met = compute_observed_metrics(l_lst, warm_idx, months_arr)

        row = {
            "sample_city_id": int(e["sample_city_id"]),
            "sample_city_name": str(e["sample_city_name"]),
            "sample_year": int(e["sample_year"]),
            "early_pixel_key": e["pixel_key"],
            "late_pixel_key": l["pixel_key"],

            "early_onset_month": float(e["t_EVI_onset_month"]),
            "late_onset_month": float(l["t_EVI_onset_month"]),
            "onset_gap_months": float(s["onset_gap"]),

            "control_distance": float(s["control_distance"]),
            "evi_shape_rmse": float(s["evi_shape_rmse"]) if np.isfinite(s["evi_shape_rmse"]) else np.nan,
            "match_score": float(s["score"]),

            "early_warm_p95": e_met["warm_p95"],
            "late_warm_p95": l_met["warm_p95"],
            "observed_d_warm_p95": e_met["warm_p95"] - l_met["warm_p95"],
            "observed_cooling_p95": l_met["warm_p95"] - e_met["warm_p95"],

            "early_heat_load": e_met["heat_load"],
            "late_heat_load": l_met["heat_load"],
            "observed_d_heat_load": e_met["heat_load"] - l_met["heat_load"],
            "observed_cooling_heat_load": l_met["heat_load"] - e_met["heat_load"],

            "early_peak_doy": e_met["peak_doy"],
            "late_peak_doy": l_met["peak_doy"],
            "observed_d_peak_time": e_met["peak_doy"] - l_met["peak_doy"],
        }

        for mm, m in enumerate(TRAJ_MONTHS):
            row[f"early_LST_m{m:02d}"] = float(e_lst[mm])
            row[f"late_LST_m{m:02d}"] = float(l_lst[mm])
            row[f"cooling_m{m:02d}"] = float(l_lst[mm] - e_lst[mm])

            row[f"early_EVI_m{m:02d}"] = float(e[f"EVI_m{m:02d}"])
            row[f"late_EVI_m{m:02d}"] = float(l[f"EVI_m{m:02d}"])

        pair_rows.append(row)

    pairs = pd.DataFrame(pair_rows)

    # Balance
    matched_early = early.iloc[[s["early_i"] for s in selected]].copy()
    matched_late = late.iloc[[s["late_j"] for s in selected]].copy()

    before_smd = []
    after_smd = []

    for c in control_cols:
        before_smd.append(abs(standardized_mean_difference(early[c], late[c])))
        after_smd.append(abs(standardized_mean_difference(matched_early[c], matched_late[c])))

    summary = {
        "sample_city_id": int(pairs["sample_city_id"].iloc[0]),
        "sample_city_name": str(pairs["sample_city_name"].iloc[0]),
        "sample_year": int(pairs["sample_year"].iloc[0]),

        "n_pairs": int(len(pairs)),
        "mean_onset_gap_months": float(pairs["onset_gap_months"].mean()),

        "mean_observed_d_warm_p95": float(pairs["observed_d_warm_p95"].mean()),
        "median_observed_d_warm_p95": float(pairs["observed_d_warm_p95"].median()),
        "frac_pairs_p95_cooling": float((pairs["observed_d_warm_p95"] < 0).mean()),

        "mean_observed_d_heat_load": float(pairs["observed_d_heat_load"].mean()),
        "median_observed_d_heat_load": float(pairs["observed_d_heat_load"].median()),
        "frac_pairs_heat_load_reduction": float((pairs["observed_d_heat_load"] < 0).mean()),

        "mean_observed_d_peak_time": float(pairs["observed_d_peak_time"].mean()),
        "median_observed_d_peak_time": float(pairs["observed_d_peak_time"].median()),
        "frac_pairs_peak_delayed": float((pairs["observed_d_peak_time"] > 0).mean()),

        "mean_control_distance": float(pairs["control_distance"].mean()),
        "mean_evi_shape_rmse": float(pairs["evi_shape_rmse"].mean()),
        "before_smd_mean_abs": float(np.nanmean(before_smd)),
        "after_smd_mean_abs": float(np.nanmean(after_smd)),
    }

    # Ranking score: prefer similarity + ML-consistent signs
    # More negative p95/heat_load and more positive peak_time are better.
    summary["ml_consistency_score"] = (
        -5.0 * summary["mean_observed_d_warm_p95"]
        -0.05 * summary["mean_observed_d_heat_load"]
        +0.05 * summary["mean_observed_d_peak_time"]
        -0.5 * summary["after_smd_mean_abs"]
        -0.8 * summary["mean_evi_shape_rmse"]
    )

    return pairs, summary

