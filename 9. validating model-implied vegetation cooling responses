py["annual_EVI_min"] = evi_wide.min(axis=1).values
py["annual_EVI_amp"] = py["annual_EVI_max"] - py["annual_EVI_min"]
py["spring_EVI_mean"] = evi_wide[PRE_MONTHS].mean(axis=1).values
py["warm_EVI_mean"] = evi_wide[WARM_MONTHS].mean(axis=1).values

# LST trajectory
for m in TRAJ_MONTHS:
