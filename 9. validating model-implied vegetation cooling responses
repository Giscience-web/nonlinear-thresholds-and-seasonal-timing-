def make_wide(value_col, aggfunc="mean"):
    w = monthly.pivot_table(
        index=idx_cols,
        columns="sample_month",
        values=value_col,
        aggfunc=aggfunc
    )
    for m in range(1, 13):
        if m not in w.columns:
            w[m] = np.nan
    return w[range(1, 13)]

evi_wide = make_wide(TIMING_FEATURE, "median")
lst_wide = make_wide("LST_anom_cym", "mean")

py = evi_wide.reset_index()[idx_cols].copy()
py["t_EVI_onset_month"] = rowwise_onset(evi_wide)

# EVI trajectory metrics
py["annual_EVI_mean"] = evi_wide.mean(axis=1).values
