def summarize_marginal_capacity(mcc_df, response_df, drop_frac=0.25):
    rows = []

    for (gtype, group), sub in mcc_df.groupby(["group_type", "group"]):
        sub = sub.sort_values("x_mid").reset_index(drop=True)

        curve = response_df[
            (response_df["group_type"] == gtype) &
            (response_df["group"] == group)
        ].sort_values("x_target_mean").reset_index(drop=True)

        if sub.empty or curve.empty:
            continue

        s = sub["marginal_cooling_capacity_smooth"].values.astype(float)
        x = sub["x_mid"].values.astype(float)

        positive = s[np.isfinite(s) & (s > 0)]

        if len(positive) > 0:
            max_mcc = float(np.nanmax(positive))
            idx_peak = int(np.nanargmax(s))
            x_peak = float(x[idx_peak])
            drop_threshold = drop_frac * max_mcc

            x_drop = np.nan
            for j in range(idx_peak + 1, len(s)):
                if np.isfinite(s[j]) and s[j] <= drop_threshold:
                    x_drop = float(x[j])
                    break
        else:
            max_mcc = np.nan
            x_peak = np.nan
            drop_threshold = np.nan
            x_drop = np.nan

        # cumulative cooling benefit info
        max_cb = float(curve["mean_cooling_benefit"].max())
        x_at_max_cb = float(curve.loc[curve["mean_cooling_benefit"].idxmax(), "x_target_mean"])
        final_cb = float(curve["mean_cooling_benefit"].iloc[-1])
        final_x = float(curve["x_target_mean"].iloc[-1])

        # average marginal capacity over early / mid / high EVI ranges
        early = sub[sub["x_mid"] <= sub["x_mid"].quantile(1/3)]
        mid = sub[
            (sub["x_mid"] > sub["x_mid"].quantile(1/3)) &
            (sub["x_mid"] <= sub["x_mid"].quantile(2/3))
        ]
        high = sub[sub["x_mid"] > sub["x_mid"].quantile(2/3)]

        rows.append({
            "feature": FEATURE,
            "group_type": gtype,
            "group": group,
            "n_segments": int(len(sub)),

            "max_cooling_benefit": max_cb,
            "x_at_max_cooling_benefit": x_at_max_cb,
            "final_cooling_benefit": final_cb,
            "final_x": final_x,

            "max_marginal_cooling_capacity": max_mcc,
            "x_at_max_marginal_capacity": x_peak,
            "drop_threshold_fraction": drop_frac,
            "drop_threshold_value": drop_threshold,
            "x_marginal_capacity_drop": x_drop,

            "mean_MCC_early_EVI": float(early["marginal_cooling_capacity_smooth"].mean()),
            "mean_MCC_mid_EVI": float(mid["marginal_cooling_capacity_smooth"].mean()),
            "mean_MCC_high_EVI": float(high["marginal_cooling_capacity_smooth"].mean()),

            "frac_positive_MCC": float((sub["marginal_cooling_capacity"] > 0).mean()),
            "frac_positive_MCC_smooth": float((sub["marginal_cooling_capacity_smooth"] > 0).mean()),
        })

    return pd.DataFrame(rows)


