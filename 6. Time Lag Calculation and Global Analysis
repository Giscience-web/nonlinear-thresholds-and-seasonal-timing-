def get_city_years(city):
    city_dir = os.path.join(ROOT, city)

    if not os.path.isdir(city_dir):
        return []

    years = []
    for f in os.listdir(city_dir):
        if f.endswith(".tif") and "_EVI_8day_0p1deg_" in f:
            m = re.search(r"(\d{4})\.tif$", f)
            if m:
                years.append(int(m.group(1)))

    return sorted(set(years))


def summarize_lag_values(v):
    v = np.asarray(v, dtype=float)
    v = v[np.isfinite(v)]
    v = v[(v > VALID_LAG_MIN) & (v < VALID_LAG_MAX)]

    if v.size == 0:
        return None

    q25, q75 = np.nanpercentile(v, [25, 75])

    return {
        "lag_mean": float(np.nanmean(v)),
        "lag_median": float(np.nanmedian(v)),
        "lag_std": float(np.nanstd(v)),
        "lag_iqr": float(q75 - q25),
        "lag_q25": float(q25),
        "lag_q75": float(q75),
        "lag_min": float(np.nanmin(v)),
        "lag_max": float(np.nanmax(v)),
        "frac_pos": float(np.mean(v > 0)),
        "frac_neg": float(np.mean(v < 0)),
        "frac_near_zero_16d": float(np.mean(np.abs(v) <= 16)),
        "mean_abs_lag": float(np.nanmean(np.abs(v))),
        "n_valid": int(v.size)
    }


def run_city_lag_yearly(city):
    city_dir = os.path.join(ROOT, city)

    if not os.path.isdir(city_dir):
        print(f"[{city}] City directory not found: {city_dir}")
        return None

    out_tif = os.path.join(
        LAG_OUT_DIR,
        f"{city}_Lag_days_heat_minus_LSP_positive_LSP_leads_NTL{NTL_KEEP_BRIGHTEST_PCT}_LSTDonly_fullpixels_multiyear.tif"
    )

    out_year_csv = os.path.join(
        LAG_OUT_DIR,
        f"{city}_lag_city_year_summary_NTL{NTL_KEEP_BRIGHTEST_PCT}_LSTDonly_fullpixels.csv"
    )

    if SKIP_EXISTING_TIF and os.path.exists(out_tif) and os.path.exists(out_year_csv):
        print(f"[{city}] Existing lag tif and city-year CSV found. Skipping recalculation.")
        df_year = pd.read_csv(out_year_csv)
        return {
            "city": city,
            "out_tif": out_tif,
            "city_year_rows": df_year.to_dict("records")
        }

    ntl_info = build_ntl_analysis_mask(city)

    if ntl_info is None:
        print(f"[{city}] No valid NTL analysis mask; skip.")
        return None

    H_ref = ntl_info["H"]
    W_ref = ntl_info["W"]
    tf_ref = ntl_info["transform"]
    crs_ref = ntl_info["crs"]
    mask_analysis = ntl_info["mask_analysis"]

    years = get_city_years(city)

    if not years:
        print(f"[{city}] No EVI years found; skip.")
        return None

    print(f"\n===== City: {city} | Years: {years} =====")

    lag_maps = []
    used_years = []
    city_year_rows = []

    idx_all = np.flatnonzero(mask_analysis.ravel())
    n_analysis = int(idx_all.size)

    for year in years:
        evi_path = os.path.join(city_dir, EVI_FILE_PATTERN.format(city=city, year=year))
        lst_path = os.path.join(city_dir, LST_FILE_PATTERN.format(city=city, year=year))

        if not (os.path.exists(evi_path) and os.path.exists(lst_path)):
            print(f"  [Skip] {year}: missing EVI or LST.")
            continue

        print(f"\n[{city}] Processing year {year}")

        # Print band descriptions for first processed year only
        if len(used_years) == 0:
            print_band_descriptions_once(lst_path, max_bands=10)

        EVI_raw = read_and_resample_to_grid(evi_path, H_ref, W_ref, Resampling.average)
        LST_day, lst_day_dates = extract_daytime_lst(lst_path, H_ref, W_ref)

        sanity_check_lst_units(LST_day, city, year)
        print(f"  Daytime LST bands used: {LST_day.shape[0]}")
        if len(lst_day_dates) > 0:
            print(f"  First LSTD date: {lst_day_dates[0]}, last LSTD date: {lst_day_dates[-1]}")

        evi_dates = extract_evi_dates_from_tif(evi_path)

        EVI, LST, doys, common_dates, align_mode = align_evi_lst_by_dates(
            EVI_raw=EVI_raw,
            evi_dates=evi_dates,
            LST_day=LST_day,
            lst_dates=lst_day_dates
        )

        print(f"  EVI-LSTD alignment mode: {align_mode}")
        print(f"  Aligned time steps: {EVI.shape[0]}")

        if EVI.shape[0] < MIN_VALID_POINTS or LST.shape[0] < MIN_VALID_POINTS:
            print(f"  ⚠ Too few aligned time steps; skip {year}.")
            continue

        lag_map = np.full((H_ref, W_ref), np.nan, dtype=np.float32)

        method_lsp_deriv = 0
        method_heat_deriv = 0

        print(f"  Calculating lag in NTL-filtered analysis pixels: {n_analysis}")

        for idx in tqdm(idx_all, desc=f"{city} {year} lag", leave=False):
            r = idx // W_ref
            c = idx % W_ref

            evi_ts = EVI[:, r, c]
            lst_ts = LST[:, r, c]

            if np.all(~np.isfinite(evi_ts)) or np.all(~np.isfinite(lst_ts)):
                continue

            t_lsp, method_lsp = lsp_start_time(doys, evi_ts)
            if t_lsp is None:
                continue

            t_heat, method_heat = heat_start_time(doys, lst_ts)
            if t_heat is None:
                continue

            # Core lag definition:
            # Positive lag means LSP activation precedes rapid daytime surface warming.
            lag = t_heat - t_lsp
            lag_map[r, c] = lag

            if method_lsp == "derivative":
                method_lsp_deriv += 1
            if method_heat == "derivative":
                method_heat_deriv += 1

        valid_count = int(np.isfinite(lag_map).sum())
        valid_fraction = valid_count / max(n_analysis, 1)

        if valid_count < MIN_VALID_LAG_PIXELS:
            print(f"  ⚠ {year}: too few valid lag pixels n={valid_count}; discarded.")
            continue

        stats_year = summarize_lag_values(lag_map[np.isfinite(lag_map)])
        if stats_year is None:
            continue

        row = {
            "City_name": city,
            "year": int(year),

            "ntl_year": int(ntl_info["ntl_year"]),
            "ntl_threshold": float(ntl_info["ntl_threshold"]) if np.isfinite(ntl_info["ntl_threshold"]) else np.nan,
            "ntl_min": float(NTL_MIN),
            "ntl_keep_brightest_pct": float(NTL_KEEP_BRIGHTEST_PCT),
            "n_total_pixels": int(ntl_info["n_total_pixels"]),
            "n_ntl_positive": int(ntl_info["n_ntl_positive"]),
            "n_analysis_pixels": int(n_analysis),

            "valid_lag_pixels": int(valid_count),
            "valid_fraction": float(valid_fraction),

            "method_lsp_derivative_count": int(method_lsp_deriv),
            "method_heat_derivative_count": int(method_heat_deriv),
            "allow_peak_fallback": bool(ALLOW_PEAK_FALLBACK),

            "lst_used": "LSTD_only",
            "n_lstd_bands": int(LST_day.shape[0]),
            "n_aligned_steps": int(EVI.shape[0]),
            "align_mode": align_mode,

            "lag_definition": "lag=t_heat-t_LSP; positive means LSP activation precedes rapid daytime surface warming"
        }

        row.update(stats_year)

        city_year_rows.append(row)
        lag_maps.append(lag_map)
        used_years.append(year)

        print(
            f"  ✅ {year}: valid={valid_count}, "
            f"valid_frac={valid_fraction:.3f}, "
            f"mean={stats_year['lag_mean']:.1f}, "
            f"median={stats_year['lag_median']:.1f}, "
            f"IQR={stats_year['lag_iqr']:.1f}, "
            f"frac_pos={stats_year['frac_pos']:.2f}"
        )

    if not lag_maps:
        print(f"[{city}] No valid lag maps generated.")
        return None

    lag_cube = np.stack(lag_maps, axis=0).astype(np.float32)

    profile = {
        "driver": "GTiff",
        "height": H_ref,
        "width": W_ref,
        "count": lag_cube.shape[0],
        "dtype": "float32",
        "crs": crs_ref,
        "transform": tf_ref,
        "compress": "LZW",
        "tiled": False,
        "nodata": np.float32(np.nan)
    }

    with rasterio.open(out_tif, "w", **profile) as dst:
        for i, year in enumerate(used_years):
            dst.write(lag_cube[i, :, :], i + 1)
            dst.set_band_description(
                i + 1,
                f"lag=t_heat-t_LSP; positive=LSP leads daytime warming; year={year}"
            )

        dst.update_tags(
            city=city,
            years=",".join(str(y) for y in used_years),
            lag_definition="lag = t_heat - t_LSP; positive means LSP activation precedes rapid daytime surface warming",
            lst_used="LSTD_only",
            ntl_year=str(ntl_info["ntl_year"]),
            ntl_mask="fixed NTL-based urban analysis mask",
            ntl_min=str(NTL_MIN),
            ntl_keep_brightest_pct=str(NTL_KEEP_BRIGHTEST_PCT),
            allow_peak_fallback=str(ALLOW_PEAK_FALLBACK),
            note="All pixels passing the NTL-filtered analysis mask were used; no random pixel cap was applied."
        )

    df_year = pd.DataFrame(city_year_rows)
    df_year.to_csv(out_year_csv, index=False, encoding="utf-8")

    print(f"[{city}] ✅ Saved lag cube: {out_tif}")
    print(f"[{city}] ✅ Saved city-year summary: {out_year_csv}")

    return {
        "city": city,
        "out_tif": out_tif,
        "city_year_rows": city_year_rows
    }


