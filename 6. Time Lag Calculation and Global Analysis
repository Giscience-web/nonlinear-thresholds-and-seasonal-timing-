def read_and_resample_to_grid(path, out_height, out_width, resampling=Resampling.average):
    with rasterio.open(path) as ds:
        arr = ds.read(
            out_shape=(ds.count, out_height, out_width),
            resampling=resampling
        ).astype(np.float32)

        nodata = ds.nodata
        if nodata is None:
            arr[arr <= -9990] = np.nan
        else:
            arr[arr == nodata] = np.nan

    return arr


