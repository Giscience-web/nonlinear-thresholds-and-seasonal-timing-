def extract_daytime_lst(path, out_height, out_width):
    """
    Read only daytime LST bands from an LST stack.

    Expected band descriptions:
        LSTD_YYYYMMDD, LSTN_YYYYMMDD, LSTD_YYYYMMDD, LSTN_YYYYMMDD, ...

    Returns:
        LST_day: (T, H, W)
        day_dates: list of date strings such as YYYYMMDD
    """
    with rasterio.open(path) as ds:
        descs = list(ds.descriptions)
        if descs is None or len(descs) != ds.count:
            descs = [None] * ds.count

        day_band_ids = []
        day_dates = []

        for i, desc in enumerate(descs, start=1):
            d = "" if desc is None else str(desc).upper()

            # Use only daytime LST bands
            if d.startswith("LSTD"):
                day_band_ids.append(i)
                m = re.search(r"(\d{8})", d)
                day_dates.append(m.group(1) if m else None)

        # Fallback if descriptions are missing
        if len(day_band_ids) == 0:
            print("  ⚠ No LSTD band descriptions found; assuming odd bands are daytime LST.")
            day_band_ids = list(range(1, ds.count + 1, 2))
            day_dates = [None] * len(day_band_ids)

        arr = ds.read(
            indexes=day_band_ids,
            out_shape=(len(day_band_ids), out_height, out_width),
            resampling=Resampling.average,
            masked=True
        ).astype(np.float32)

        if np.ma.isMaskedArray(arr):
            arr = arr.filled(np.nan)

        nodata = ds.nodata
        if nodata is None:
            arr[arr <= -9990] = np.nan
        else:
            arr[arr == nodata] = np.nan

    return arr, day_dates


def extract_evi_dates_from_tif(path):
    """
    Try to read EVI band dates from band descriptions.
    Returns list of YYYYMMDD or None values.
    """
    dates = []
    try:
        with rasterio.open(path) as ds:
            descs = list(ds.descriptions)
            if descs is None or len(descs) != ds.count:
                return [None] * ds.count

            for desc in descs:
                d = "" if desc is None else str(desc)
                m = re.search(r"(\d{8})", d)
                dates.append(m.group(1) if m else None)
    except Exception:
        return []
    return dates


def sanity_check_lst_units(lst_arr, city, year):
    v = lst_arr[np.isfinite(lst_arr)]
    if v.size == 0:
        return

    p1, p50, p99 = np.nanpercentile(v, [1, 50, 99])
    print(f"  Daytime LST sanity {city} {year}: p1={p1:.2f}, p50={p50:.2f}, p99={p99:.2f}")

    if p50 > 200:
        print("  ⚠ LST median > 200. Check whether LST is Kelvin or unscaled MODIS integer.")


