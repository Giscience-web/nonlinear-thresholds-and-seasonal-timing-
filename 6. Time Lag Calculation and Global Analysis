        raise FileNotFoundError(f"City metadata not found: {city_info_path}")

    if city_info_path.lower().endswith((".xlsx", ".xls")):
        df = pd.read_excel(city_info_path)
    else:
        df = pd.read_csv(city_info_path)

    city_col = find_col(
        df,
        exact_candidates=["city", "city_name", "cityname", "name", "city name"],
        contains_any=["city"]
    )

    lat_col = find_col(
        df,
        exact_candidates=["lat", "latitude"],
        contains_any=["lat"]
    )

    lon_col = find_col(
        df,
        exact_candidates=["lon", "longitude", "lng"],
        contains_any=["lon", "lng"]
    )

    koppen_col = find_col(
        df,
        exact_candidates=["koppen_code", "koppen", "koppen-geiger", "koppen_geiger"],
        contains_any=["koppen"]
    )

    koppen_name_col = find_col(
        df,
        exact_candidates=["koppen_full_name", "koppen_name", "climate_full_name"],
        contains_any=["full_name"]
    )

    if city_col is None:
        raise ValueError("Cannot find city column in city metadata.")

    out = df.copy()
    out["City_key"] = out[city_col].apply(norm_city)

    rename = {city_col: "City_name_meta"}
    if lat_col is not None:
        rename[lat_col] = "Lat"
    if lon_col is not None:
        rename[lon_col] = "Lon"
    if koppen_col is not None:
        rename[koppen_col] = "koppen_code"
    if koppen_name_col is not None:
        rename[koppen_name_col] = "koppen_full_name"

    out = out.rename(columns=rename)

    if "koppen_code" not in out.columns:
        warnings.warn("No koppen_code column found. Climate-zone analysis will be skipped.")
        out["koppen_code"] = np.nan

    if "koppen_full_name" not in out.columns:
        out["koppen_full_name"] = np.nan

    keep_cols = ["City_key", "City_name_meta", "Lat", "Lon", "koppen_code", "koppen_full_name"]
    keep_cols = [c for c in keep_cols if c in out.columns]

    return out[keep_cols].drop_duplicates("City_key")


