def align_evi_lst_by_dates(EVI_raw, evi_dates, LST_day, lst_dates):
    """
    Align EVI and LSTD by exact YYYYMMDD dates when both date lists are available.

    If dates are missing or no overlap exists, fallback to min-length truncation.
    """
    has_evi_dates = evi_dates and all(d is not None for d in evi_dates)
    has_lst_dates = lst_dates and all(d is not None for d in lst_dates)

    if has_evi_dates and has_lst_dates:
        evi_date_to_idx = {d: i for i, d in enumerate(evi_dates)}
        lst_date_to_idx = {d: i for i, d in enumerate(lst_dates)}
        common_dates = sorted(set(evi_date_to_idx.keys()) & set(lst_date_to_idx.keys()))

        if len(common_dates) >= MIN_VALID_POINTS:
            evi_idx = [evi_date_to_idx[d] for d in common_dates]
            lst_idx = [lst_date_to_idx[d] for d in common_dates]

            EVI_aligned = EVI_raw[evi_idx, :, :]
            LST_aligned = LST_day[lst_idx, :, :]

            # DOY from common dates
            doys = []
            for d in common_dates:
                year = int(d[:4])
                month = int(d[4:6])
                day = int(d[6:8])
                dt = pd.Timestamp(year=year, month=month, day=day)
                doys.append(float(dt.dayofyear))

            return EVI_aligned, LST_aligned, np.array(doys, dtype=np.float32), common_dates, "date_intersection"

    # Fallback to min-length truncation
    T = min(EVI_raw.shape[0], LST_day.shape[0])
    EVI_aligned = EVI_raw[:T, :, :]
    LST_aligned = LST_day[:T, :, :]
    doys = np.arange(T, dtype=np.float32) * 8.0 + 4.0

    return EVI_aligned, LST_aligned, doys, None, "min_length_truncation"


