def find_koppen_raster(koppen_dir):
    if not os.path.exists(koppen_dir):
        raise FileNotFoundError(f"Köppen directory not found: {koppen_dir}")

    candidates = []

    for root, dirs, files in os.walk(koppen_dir):
        for f in files:
            fl = f.lower()
            if fl.endswith((".tif", ".tiff")):
                path = os.path.join(root, f)

                # Prefer files that look like classification maps rather than thumbnails.
                score = 0
                if "koppen" in fl or "kg" in fl:
                    score += 2
                if "1991" in fl or "2020" in fl:
                    score += 2
                if "class" in fl or "map" in fl:
                    score += 1

                candidates.append((score, path))

    if len(candidates) == 0:
        raise FileNotFoundError(
            f"No .tif/.tiff file found under {koppen_dir}. "
            "Please check whether the 1991_2020 folder contains GeoTIFF files."
        )

    candidates = sorted(candidates, key=lambda x: (-x[0], x[1]))

    print("Candidate Köppen rasters:")
    for score, path in candidates:
        print(f"score={score}: {path}")

    return candidates[0][1]


