def smooth_1d_interp_edge(x, win=5):
    """
    Interpolate missing values and apply edge-padded moving average.
    This avoids zero-padding artifacts at the beginning/end of the year.
    """
    x = np.asarray(x, dtype=float)
    n = len(x)

    if n == 0:
        return x.copy()

    valid = np.isfinite(x)

    if valid.sum() < 2:
        return np.full(n, np.nan, dtype=float)

    x_interp = np.interp(np.arange(n), np.arange(n)[valid], x[valid])

    if win <= 1 or win >= n:
        return x_interp

    pad = win // 2
    x_pad = np.pad(x_interp, pad_width=pad, mode="edge")
    kernel = np.ones(win, dtype=float) / float(win)
    y = np.convolve(x_pad, kernel, mode="valid")

    return y[:n]


def find_fastest_stable_increase(
    doys,
    values,
    win_smooth=SMOOTH_WIN,
    diff_smooth_win=DIFF_SMOOTH_WIN,
    win_check=WIN_CHECK,
    min_valid=MIN_VALID_POINTS,
    tol_neg=TOL_NEG
):
    """
    Identify the onset of rapid stable increase.

    Returns:
        (t_onset, method)
        method = "derivative" when successfully detected.
        (None, None) when no reliable onset is found.
    """
    values = np.asarray(values, dtype=float)
    doys = np.asarray(doys, dtype=float)

    if np.isfinite(values).sum() < min_valid:
        return None, None

    x = smooth_1d_interp_edge(values, win=win_smooth)

    if np.isfinite(x).sum() < min_valid:
        return None, None

    diff = np.diff(x)
    if diff.size == 0:
        return None, None

    pos_mask = diff > 0
    if not np.any(pos_mask):
        return None, None

    if diff_smooth_win > 1 and len(diff) >= diff_smooth_win:
        pad = diff_smooth_win // 2
        diff_pad = np.pad(diff, pad_width=pad, mode="edge")
        kernel = np.ones(diff_smooth_win, dtype=float) / float(diff_smooth_win)
        diff_s = np.convolve(diff_pad, kernel, mode="valid")[:len(diff)]
    else:
        diff_s = diff.copy()

    candidate_idx = np.where(pos_mask)[0]

    best_t = None
    best_val = -np.inf

    for i in candidate_idx:
        l = max(0, i - win_check)
        r = min(len(diff), i + win_check + 1)
        local = diff[l:r]

        if local.size == 0:
            continue

        local_max = np.nanmax(local)
        local_min = np.nanmin(local)

        if not np.isfinite(local_max) or local_max <= 0:
            continue

        # Stable increase: avoid a local window with strong negative reversal.
        if local_min < -tol_neg * local_max:
            continue

        if diff_s[i] > best_val:
            best_val = diff_s[i]
            best_t = float(doys[i + 1])

    if best_t is None:
        return None, None

    return best_t, "derivative"


def lsp_start_time(doys, evi_ts):
    """
    LSP activation timing derived from EVI trajectory.
    This is land-surface phenology, not plant-level phenology.
    """
    evi_ts = np.asarray(evi_ts, dtype=float)
    valid = np.isfinite(evi_ts)

    if valid.sum() < MIN_VALID_POINTS:
        return None, None

    if np.nanmax(evi_ts[valid]) < MIN_EVI_FOR_VEG:
        return None, None

    t, method = find_fastest_stable_increase(doys, evi_ts)

    if t is not None:
        return t, method

    if ALLOW_PEAK_FALLBACK:
        x_sm = smooth_1d_interp_edge(evi_ts, win=SMOOTH_WIN)
        if np.isfinite(x_sm).sum() >= MIN_VALID_POINTS:
            return float(doys[int(np.nanargmax(x_sm))]), "peak_fallback"

    return None, None


def heat_start_time(doys, lst_ts):
    """
    Rapid daytime surface warming onset timing derived from LSTD trajectory.
    """
    lst_ts = np.asarray(lst_ts, dtype=float)
    valid = np.isfinite(lst_ts)

    if valid.sum() < MIN_VALID_POINTS:
        return None, None

    t, method = find_fastest_stable_increase(doys, lst_ts)

    if t is not None:
        return t, method

    if ALLOW_PEAK_FALLBACK:
        x_sm = smooth_1d_interp_edge(lst_ts, win=SMOOTH_WIN)
        if np.isfinite(x_sm).sum() >= MIN_VALID_POINTS:
            return float(doys[int(np.nanargmax(x_sm))]), "peak_fallback"

    return None, None


