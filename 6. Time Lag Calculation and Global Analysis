            return c

    return None


def clean_lon_lat(lon, lat):
    try:
        lon = float(lon)
        lat = float(lat)
    except Exception:
        return np.nan, np.nan

    # normalize longitude to [-180, 180]
    if lon > 180:
        lon = ((lon + 180) % 360) - 180

    return lon, lat


def sample_raster_mode_around_point(ds, lon, lat, radius_pixels=1):
    """
    Sample raster value at lon/lat.
    If direct point is nodata, use mode in a small neighborhood.
    """
    if not np.isfinite(lon) or not np.isfinite(lat):
        return np.nan

    # Transform lon/lat to raster CRS
    if ds.crs is not None and ds.crs.to_string() not in ["EPSG:4326", "OGC:CRS84"]:
        transformer = Transformer.from_crs("EPSG:4326", ds.crs, always_xy=True)
        x, y = transformer.transform(lon, lat)
    else:
        x, y = lon, lat

    try:
        row, col = ds.index(x, y)
    except Exception:
        return np.nan

    if row < 0 or row >= ds.height or col < 0 or col >= ds.width:
        return np.nan

    arr = ds.read(1)
    nodata = ds.nodata

    def valid_value(v):
        if nodata is not None and v == nodata:
            return False
        if not np.isfinite(v):
            return False
        if v <= 0:
            return False
        return True

    val = arr[row, col]
    if valid_value(val):
        return int(val)

    # neighborhood fallback
    r0 = max(0, row - radius_pixels)
    r1 = min(ds.height, row + radius_pixels + 1)
    c0 = max(0, col - radius_pixels)
    c1 = min(ds.width, col + radius_pixels + 1)

    win = arr[r0:r1, c0:c1].ravel()
    valid = [int(v) for v in win if valid_value(v)]

    if len(valid) == 0:
        return np.nan

    vals, counts = np.unique(valid, return_counts=True)
    return int(vals[np.argmax(counts)])


