    plt.axvline(0, color="gray", linestyle="-", linewidth=1)
    plt.xlabel("City-level year-balanced mean lag (days)")
    plt.ylabel("Number of cities")
    plt.title("Distribution of LSP–daytime LST seasonal alignment")
    plt.legend()
    plt.tight_layout()

    hist_png = os.path.join(GLOBAL_OUT_DIR, f"city_lag_mean_hist_year_balanced_NTL{NTL_KEEP_BRIGHTEST_PCT}_LSTDonly_fullpixels.png")
    plt.savefig(hist_png, dpi=250)
    plt.close()

    print("🖼 Saved histogram:", hist_png)

    print("\n=== Global lag summary ===")
    summary_cols = [
        "lag_mean", "lag_median", "lag_iqr",
        "mean_abs_lag", "frac_pos", "frac_neg",
        "frac_near_zero_16d", "valid_fraction_mean"
    ]
    print(df[summary_cols].describe())

    # ------------------------------------------------------------
    # 8.4 Climate-zone analysis
    # ------------------------------------------------------------
    if "koppen_code" in df.columns and df["koppen_code"].notna().sum() > 0:
        df_clim = df.dropna(subset=["koppen_code", "lag_mean"]).copy()

        if "koppen_full_name" not in df_clim.columns:
            df_clim["koppen_full_name"] = df_clim["koppen_code"]

        clim_stats = (
            df_clim
            .groupby(["koppen_code", "koppen_full_name"])
            .agg(
                n_cities=("City_name", "nunique"),
                lag_mean_clim=("lag_mean", "mean"),
                lag_std_clim=("lag_mean", "std"),
                lag_median_clim=("lag_median", "mean"),
                lag_iqr_clim=("lag_iqr", "mean"),
                mean_abs_lag_clim=("mean_abs_lag", "mean"),
                frac_pos_clim=("frac_pos", "mean"),
                frac_neg_clim=("frac_neg", "mean"),
                valid_fraction_clim=("valid_fraction_mean", "mean")
            )
            .reset_index()
            .sort_values("lag_mean_clim")
        )

        clim_csv = os.path.join(GLOBAL_OUT_DIR, f"lag_by_koppen_zone_year_balanced_NTL{NTL_KEEP_BRIGHTEST_PCT}_LSTDonly_fullpixels.csv")
        clim_stats.to_csv(clim_csv, index=False, encoding="utf-8")
        print("\n✅ Saved climate-zone stats:", clim_csv)
        print(clim_stats.to_string(index=False))

        labels = []
        for _, row in clim_stats.iterrows():
            if isinstance(row["koppen_full_name"], str) and row["koppen_full_name"] != "nan":
                labels.append(f"{row['koppen_code']}\n{row['koppen_full_name']}")
            else:
                labels.append(str(row["koppen_code"]))

        plt.figure(figsize=(max(8.5, 0.75 * len(clim_stats)), 5.2))
        x = np.arange(len(clim_stats))
        plt.bar(
            x,
            clim_stats["lag_mean_clim"],
            yerr=clim_stats["lag_std_clim"],
            alpha=0.75,
            capsize=4
        )
        plt.axhline(0, color="gray", linestyle="--", linewidth=1)
        plt.xticks(x, labels, rotation=45, ha="right")
        plt.ylabel("Mean city-level lag (days)")
        plt.title("Climate-zone differences in LSP–daytime LST seasonal alignment")
        plt.tight_layout()

        clim_png = os.path.join(GLOBAL_OUT_DIR, f"lag_by_koppen_zone_year_balanced_NTL{NTL_KEEP_BRIGHTEST_PCT}_LSTDonly_fullpixels.png")
        plt.savefig(clim_png, dpi=250)
        plt.close()

        print("🖼 Saved climate-zone figure:", clim_png)

        # Pairwise KS test with Holm correction.
        # Only test groups with at least 5 cities.
        groups = {
            k: g["lag_mean"].dropna().values
            for k, g in df_clim.groupby("koppen_code")
            if g["lag_mean"].dropna().shape[0] >= 5
        }

        pair_rows = []
        codes = sorted(groups.keys())

        for i in range(len(codes)):
            for j in range(i + 1, len(codes)):
                a = codes[i]
                b = codes[j]
                stat, p = stats.ks_2samp(groups[a], groups[b])
                pair_rows.append({
                    "group1": a,
                    "group2": b,
                    "n1": len(groups[a]),
                    "n2": len(groups[b]),
                    "ks_stat": float(stat),
                    "p_raw": float(p)
                })

        if pair_rows:
            df_pair = pd.DataFrame(pair_rows).sort_values("p_raw").reset_index(drop=True)
            m = len(df_pair)

            p_raw = df_pair["p_raw"].values
            p_holm = np.empty_like(p_raw, dtype=float)

            for rank, p in enumerate(p_raw, start=1):
                p_holm[rank - 1] = min((m - rank + 1) * p, 1.0)

            p_holm = np.maximum.accumulate(p_holm)

            df_pair["p_holm"] = p_holm
            df_pair["significant_0p05"] = df_pair["p_holm"] < 0.05

            pair_csv = os.path.join(GLOBAL_OUT_DIR, f"koppen_pairwise_ks_holm_NTL{NTL_KEEP_BRIGHTEST_PCT}_LSTDonly_fullpixels.csv")
            df_pair.to_csv(pair_csv, index=False, encoding="utf-8")
            print("✅ Saved pairwise KS + Holm tests:", pair_csv)
        else:
            print("No climate groups with n >= 5 for pairwise KS tests.")

    else:
        print("\n⚠ No valid Köppen code available. Climate-zone analysis skipped.")

    # ------------------------------------------------------------
    # 8.5 Latitude analysis
    # ------------------------------------------------------------
    if "Lat" in df.columns and df["Lat"].notna().sum() >= 3:
        df_lat = df.dropna(subset=["Lat", "lag_mean"]).copy()

        plt.figure(figsize=(6.4, 4.4))
        plt.scatter(df_lat["Lat"], df_lat["lag_mean"], s=38, alpha=0.75)

        if HAS_LOWESS and len(df_lat) >= 5:
            low = lowess(df_lat["lag_mean"], df_lat["Lat"], frac=0.5)
            plt.plot(low[:, 0], low[:, 1], "k-", lw=2, label="LOWESS")
            plt.legend()

        plt.axhline(0, linestyle="--", color="gray", linewidth=1)
        plt.xlabel("Latitude (°)")
        plt.ylabel("City-level year-balanced mean lag (days)")
        plt.title("Latitude–lag relationship")
        plt.tight_layout()

        lat_png = os.path.join(GLOBAL_OUT_DIR, f"lat_vs_lag_mean_year_balanced_NTL{NTL_KEEP_BRIGHTEST_PCT}_LSTDonly_fullpixels.png")
        plt.savefig(lat_png, dpi=250)
        plt.close()

        print("🖼 Saved latitude scatter:", lat_png)

        if len(df_lat) >= 3:
            r, p = stats.pearsonr(df_lat["Lat"], df_lat["lag_mean"])
            print(f"\nLatitude vs lag_mean: Pearson r={r:.3f}, p={p:.3e}")

        bins = np.arange(-60, 75, 5)
        df_lat["lat_bin"] = pd.cut(df_lat["Lat"], bins)

        band_stats = (
            df_lat
            .groupby("lat_bin", observed=True)
            .agg(
                n_cities=("City_name", "nunique"),
                lat_center=("Lat", "mean"),
                lag_mean_band=("lag_mean", "mean"),
                lag_std_band=("lag_mean", "std"),
                lag_median_band=("lag_median", "mean"),
                mean_abs_lag_band=("mean_abs_lag", "mean"),
                valid_fraction_band=("valid_fraction_mean", "mean")
            )
            .reset_index()
            .dropna(subset=["lat_center"])
            .sort_values("lat_center")
        )

        band_csv = os.path.join(GLOBAL_OUT_DIR, f"lag_by_latitude_band_year_balanced_NTL{NTL_KEEP_BRIGHTEST_PCT}_LSTDonly_fullpixels.csv")
        band_stats.to_csv(band_csv, index=False, encoding="utf-8")
        print("✅ Saved latitude-band stats:", band_csv)

        plt.figure(figsize=(6.5, 4.2))
        plt.errorbar(
            band_stats["lat_center"],
            band_stats["lag_mean_band"],
            yerr=band_stats["lag_std_band"],
            fmt="o-",
            capsize=3
        )
        plt.axhline(0, linestyle="--", color="gray", linewidth=1)
        plt.xlabel("Latitude band center (°)")
        plt.ylabel("Mean lag (days)")
        plt.title("Latitude-band mean lag")
        plt.tight_layout()

        band_png = os.path.join(GLOBAL_OUT_DIR, f"lat_band_lag_mean_year_balanced_NTL{NTL_KEEP_BRIGHTEST_PCT}_LSTDonly_fullpixels.png")
        plt.savefig(band_png, dpi=250)
        plt.close()

        print("🖼 Saved latitude-band figure:", band_png)

    else:
        print("\n⚠ Latitude column not available or insufficient data. Latitude analysis skipped.")

    print("\n🎉 Full-pixel revised Time Lag Calculation and Global Analysis complete.")

# -*- coding: utf-8 -*-
# ============================================================
# Fig. 4 | Clean main-text version
# No correlation values, no sample-size labels, no numeric text boxes
# ============================================================

import os
import numpy as np
import pandas as pd
import matplotlib.pyplot as plt

try:
    from statsmodels.nonparametric.smoothers_lowess import lowess
    HAS_LOWESS = True
except Exception:
    HAS_LOWESS = False

# =========================
# 0. Paths
# =========================
BASE_DIR = "/content/drive/MyDrive/anature_revised"

CSV_CANDIDATES = [
    f"{BASE_DIR}/lag_global_analysis_revised_fullpixels_LSTDonly/lag_city_year_balanced_with_metadata_NTL50_LSTDonly_fullpixels.csv",
    f"{BASE_DIR}/lag_global_analysis/lag_city_year_balanced_with_metadata_NTL50_LSTDonly_fullpixels.csv",
    f"{BASE_DIR}/lag_global_analysis/lag_city_summary.csv",
]

OUT_DIR = f"{BASE_DIR}/fig4_revised_maintext_clean"
os.makedirs(OUT_DIR, exist_ok=True)

csv_path = None
for p in CSV_CANDIDATES:
    if os.path.exists(p):
        csv_path = p
        break

if csv_path is None:
    raise FileNotFoundError("No city-level lag summary CSV found.")

print("Using:", csv_path)
df = pd.read_csv(csv_path)
print("Shape:", df.shape)

# =========================
# 1. Column harmonization
# =========================
def pick_col(candidates, columns, required=True):
    for c in candidates:
        if c in columns:
            return c
    if required:
        raise ValueError(f"Cannot find any column from: {candidates}")
    return None

city_col = pick_col(["City_name", "city", "City", "city_name"], df.columns)
lag_col  = pick_col(["lag_mean", "lag_mean_days", "lag_median_days", "lag_median"], df.columns)
koppen_col = pick_col(["koppen_code", "koppen", "Koppen", "koppen_subclass"], df.columns, required=False)
lat_col    = pick_col(["Lat", "lat", "Latitude", "latitude"], df.columns, required=False)

if koppen_col is None:
    raise ValueError("No Köppen climate column found.")
if lat_col is None:
    raise ValueError("No latitude column found.")

plot_df = df[[city_col, lag_col, koppen_col, lat_col]].copy()
plot_df = plot_df.rename(columns={
    city_col: "city",
    lag_col: "lag",
    koppen_col: "koppen",
    lat_col: "lat"
})

plot_df["lag"] = pd.to_numeric(plot_df["lag"], errors="coerce")
plot_df["lat"] = pd.to_numeric(plot_df["lat"], errors="coerce")
plot_df["koppen"] = plot_df["koppen"].astype(str)

plot_df = plot_df.replace([np.inf, -np.inf], np.nan)
plot_df = plot_df.dropna(subset=["lag", "koppen", "lat"]).copy()
plot_df = plot_df[~plot_df["koppen"].isin(["nan", "None", "UNK", ""])]

print("Cities used:", plot_df["city"].nunique())

# =========================
# 2. Order Köppen classes by IQR
# =========================
clim_stats = (
    plot_df.groupby("koppen")
    .agg(
        q25=("lag", lambda x: np.nanpercentile(x, 25)),
        q75=("lag", lambda x: np.nanpercentile(x, 75)),
        iqr=("lag", lambda x: np.nanpercentile(x, 75) - np.nanpercentile(x, 25)),
        n=("city", "nunique")
    )
    .reset_index()
)

# 至少保留有一定城市数的气候组
clim_stats = clim_stats[clim_stats["n"] >= 3].copy()
clim_stats = clim_stats.sort_values("iqr", ascending=False)

ordered_koppen = clim_stats["koppen"].tolist()
box_data = [
    plot_df.loc[plot_df["koppen"] == k, "lag"].dropna().values
    for k in ordered_koppen
]

# 这里只保留气候类型标签，不显示 n
labels = ordered_koppen

# =========================
# 3. Figure style
# =========================
plt.rcParams.update({
    "font.family": "DejaVu Sans",
    "font.size": 10,
    "axes.labelsize": 11,
    "axes.titlesize": 12,
    "xtick.labelsize": 9,
    "ytick.labelsize": 9,
    "figure.dpi": 140,
    "savefig.dpi": 300,
    "axes.spines.top": False,
    "axes.spines.right": False,
})

# Color palette
box_face = "#9EC5D3"
box_edge = "#365C6A"
median_col = "#B44C5C"
point_col = "#4C78A8"
scatter_col = "#5A8F5A"
lowess_col = "#1F2937"
zero_col = "#7A7A7A"

# =========================
# 4. Create figure
# =========================
fig = plt.figure(figsize=(12.2, 5.0))
gs = fig.add_gridspec(1, 2, width_ratios=[1.25, 1.0], wspace=0.25)

# -------------------------
# Panel a: Köppen boxplot
# -------------------------
ax1 = fig.add_subplot(gs[0, 0])

bp = ax1.boxplot(
    box_data,
    patch_artist=True,
    showfliers=False,
    widths=0.62,
    medianprops=dict(color=median_col, linewidth=2.0),
    boxprops=dict(linewidth=1.2, color=box_edge),
    whiskerprops=dict(linewidth=1.1, color=box_edge),
    capprops=dict(linewidth=1.1, color=box_edge)
)

for patch in bp["boxes"]:
    patch.set_facecolor(box_face)
    patch.set_alpha(0.78)

# jitter points
rng = np.random.default_rng(42)
for i, vals in enumerate(box_data, start=1):
    if len(vals) == 0:
        continue
    x = rng.normal(i, 0.05, size=len(vals))
    ax1.scatter(
        x, vals,
        s=16,
        alpha=0.45,
        color=point_col,
        edgecolor="white",
        linewidth=0.2,
        zorder=3
    )

ax1.axhline(0, color=zero_col, linestyle="--", linewidth=1.2)
ax1.set_xticks(np.arange(1, len(labels) + 1))
ax1.set_xticklabels(labels, rotation=35, ha="right")
ax1.set_ylabel("Lag = $t_{heat}$ − $t_{LSP}$ (days)")
ax1.set_title("a  Climate-zone distributions", loc="left", fontweight="bold")
ax1.grid(axis="y", linestyle=":", alpha=0.28)

# 简洁图解
ax1.text(
    0.02, 0.96,
    "Positive: LSP leads warming\nNegative: warming leads LSP",
    transform=ax1.transAxes,
    ha="left", va="top",
    fontsize=9,
    bbox=dict(boxstyle="round,pad=0.28", facecolor="white", edgecolor="#D9D9D9", alpha=0.9)
)

# -------------------------
# Panel b: Latitude gradient
# -------------------------
ax2 = fig.add_subplot(gs[0, 1])

lat_df = plot_df.dropna(subset=["lat", "lag"]).copy()
lat_df = lat_df.sort_values("lat")

ax2.scatter(
    lat_df["lat"], lat_df["lag"],
    s=34,
    alpha=0.70,
    color=scatter_col,
    edgecolor="white",
    linewidth=0.35
)

if HAS_LOWESS and len(lat_df) >= 8:
    low = lowess(lat_df["lag"], lat_df["lat"], frac=0.45, return_sorted=True)
    ax2.plot(low[:, 0], low[:, 1], color=lowess_col, linewidth=2.4)

ax2.axhline(0, color=zero_col, linestyle="--", linewidth=1.2)
ax2.set_xlabel("Latitude (°)")
ax2.set_ylabel("Lag = $t_{heat}$ − $t_{LSP}$ (days)")
ax2.set_title("b  Latitudinal gradient", loc="left", fontweight="bold")
ax2.grid(axis="both", linestyle=":", alpha=0.28)

# 简洁注释
ax2.text(
    0.03, 0.96,
    "LOWESS curve shows the broad\nlatitudinal pattern",
    transform=ax2.transAxes,
    ha="left", va="top",
    fontsize=9,
    bbox=dict(boxstyle="round,pad=0.28", facecolor="white", edgecolor="#D9D9D9", alpha=0.9)
)

# -------------------------
# Overall title
# -------------------------
fig.suptitle(
    "Seasonal alignment between land-surface phenology and daytime warming",
    fontsize=14,
    fontweight="bold",
    y=1.02
)

# Bottom note
fig.text(
    0.5, -0.02,
    "Lag is defined as the onset of rapid daytime LST warming minus the onset of rapid EVI increase.",
    ha="center",
    va="top",
    fontsize=9.2
)

plt.tight_layout()

# =========================
# 5. Save
# =========================
png_path = os.path.join(OUT_DIR, "Fig4_clean_maintext.png")
pdf_path = os.path.join(OUT_DIR, "Fig4_clean_maintext.pdf")
tif_path = os.path.join(OUT_DIR, "Fig4_clean_maintext.tif")

fig.savefig(png_path, bbox_inches="tight", dpi=300)
fig.savefig(pdf_path, bbox_inches="tight")
fig.savefig(tif_path, bbox_inches="tight", dpi=300)

plt.show()

print("Saved:")
print(" -", png_path)
print(" -", pdf_path)
print(" -", tif_path)
